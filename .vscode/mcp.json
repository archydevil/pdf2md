{
	"inputs": [
		{
			"id": "token",
			"type": "promptString",
			"description": "",
			"password": true
		}
	],
	"servers": {
		"kb-forge": {
			"type": "stdio",
			"command": "${workspaceFolder}/kb/.venv/bin/python",
