			"cwd": "${workspaceFolder}/kb",
			"env": {
				"KB_LANCEDB_DIR": "${workspaceFolder}/kb/.kbdata/lancedb",
				"KB_DATA_DIR": "${workspaceFolder}/kb/.kbdata"
			}
		}
	}
}